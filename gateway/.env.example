LISTEN_ADDR=:8080
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
EMAIL_FROM=info@tech-gate.online
EMAIL_FROM_NAME=Tech-Gate
GATEWAY_WORKER_SECRET=
WORKER_SEND_URL=
NEO_INGRESS_URL=http://172.20.0.1:3003/agent/ingress
NEO_INBOX_URL=http://172.20.0.1:3003/inbox
NEO_INGRESS_SECRET=

# WhatsApp (Twilio transport, autonomous Gemini channel). Optional — leave blank to keep the
# gateway email-only; set all three to enable POST /inbound/whatsapp. PUBLIC_URL is the gateway's
# externally-visible base URL, used to validate Twilio's X-Twilio-Signature on the webhook.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
PUBLIC_URL=https://neo-api.tech-gate.online

# Voice calling (Gemini Live ⇄ Twilio Media Streams, same subdomain). Activates when TWILIO_AUTH_TOKEN
# is set. Point your Twilio number's Voice webhook at PUBLIC_URL/voice/incoming; it returns TwiML that
# streams the call to PUBLIC_URL/voice/stream. WhatsApp Calling uses the SAME path (From="whatsapp:+…").
# GEMINI_LIVE_URL overrides the dial endpoint (default: gopkg gemini.LiveEndpoint, v1beta BidiGenerateContent).
GEMINI_LIVE_URL=
