# externally-visible base URL, used to validate Twilio's X-Twilio-Signature on the webhook.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
PUBLIC_URL=https://neo-api.tech-gate.online
