# Secrets — copy to .env (gitignored, chmod 600). Never commit real values.
TELEGRAM_TOKEN=
GEMINI_API_KEY=
# Google Stitch MCP API key (design generation). When set, OPERATOR SDK workers get the Stitch
# HTTP MCP server (https://stitch.googleapis.com/mcp, header X-Goog-Api-Key). Never used on the
# customer/ingress path. Leave blank to disable Stitch.
STITCH_API_KEY=
