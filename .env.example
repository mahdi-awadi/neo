# ─────────────────────────────────────────────────────────────────────────────
# Neo — environment secrets & deployment settings.
# Copy this file to `.env` (which is gitignored; `chmod 600 .env`) and fill it in.
# NEVER commit real values. Any variable here overrides the matching key in
# config.json. Structured, non-secret knobs (budgets, timeouts, context policy)
# live in config.json — see config.example.json and docs/CONFIG.md.
# ─────────────────────────────────────────────────────────────────────────────

# ── Required to run the operator frontends ───────────────────────────────────
# Telegram bot token from @BotFather. Without it, the Telegram bot AND the web
# console (which uses Telegram for login) are disabled; the engine still boots.
TELEGRAM_TOKEN=

# ── Web operator console ─────────────────────────────────────────────────────
# The bot's @username (WITHOUT the leading @) — required by the web console's
# Telegram Login Widget. Leave blank to have the daemon resolve it via getMe at
# startup; set it to avoid that network call (and to make login deterministic).
BOT_USERNAME=

# Interface + port the console binds. Default 127.0.0.1 (localhost only) — put a
# TLS reverse proxy (e.g. Traefik/Caddy/nginx) in front. To let a proxy on a
# docker bridge reach it, set WEB_HOST to that bridge IP (e.g. 172.17.0.1).
WEB_HOST=127.0.0.1
WEB_PORT=3003

# Public HTTPS URL the console is reached at, e.g. https://neo.example.com.
# Used for the startup hint; the Telegram Login Widget must be configured in
# @BotFather (/setdomain) with this domain for login to work. Blank → not shown.
PUBLIC_URL=

# ── Provider / customer-facing path ──────────────────────────────────────────
# Gemini API key for customer-facing reading (email/WhatsApp/voice). Customer
# I/O must never touch the Claude subscription — that firewall is enforced in
# code (provider-router.ts). Leave blank if you don't run the customer path.
GEMINI_API_KEY=

# ── Optional MCP add-ons for operator workers (all OFF when blank) ────────────
# Google Stitch MCP (design generation), attached to OPERATOR workers only.
STITCH_API_KEY=
# Path to the codebase-memory MCP binary (code intelligence). Blank → disabled.
CODEBASE_MEMORY_BIN=

# ── Customer inbox gateway (optional; Phase 3b) ──────────────────────────────
# Shared bearer secret for the machine-to-machine POST /agent/ingress + /inbox
# endpoints (the email/WhatsApp gateway authenticates with it). Blank → those
# endpoints refuse all requests.
AGENT_INGRESS_SECRET=
# Gateway /send endpoint Neo POSTs an approved inbox reply to (Neo holds no
# email/Cloudflare creds itself). Blank → replying is disabled.
GATEWAY_SEND_URL=
# Booking link the customer-reply CTA points at (blank → the reply invites the
# customer to propose times instead).
MEETING_LINK=
# Business name the customer email replies sign off as (blank → "the business";
# never "Neo").
BUSINESS_NAME=

# ── Project layout & scheduler ───────────────────────────────────────────────
# Root directory holding your project repos — the New-project picker scans it,
# the company `dispatch` tool resolves names under it, and custom loops are
# fenced to it. Default /home.
WORK_ROOT=/home
# The always-on "company" / chief-of-staff workspace (its own folder + CLAUDE.md).
# Default is an `agent/` directory next to the daemon (<repo>/agent).
COMPANY_FOLDER=
# Set to 0 to disable the autonomous loop scheduler (default on).
NEO_LOOP_SCHEDULER=1
